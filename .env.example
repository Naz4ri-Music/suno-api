SUNO_COOKIE=
TWOCAPTCHA_KEY=
BROWSER=chromium
BROWSER_GHOST_CURSOR=false
BROWSER_LOCALE=en
BROWSER_HEADLESS=true

# App runtime configuration
HOST=127.0.0.1
PORT=3000
# Build-time and runtime base path. Leave empty when serving from `/`.
# Example behind nginx reverse proxy: /tools/suno-api
APP_BASE_PATH=

# Docker published address configuration
DOCKER_BIND_HOST=127.0.0.1
DOCKER_HOST_PORT=3000
